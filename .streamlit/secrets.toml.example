# Supabase 연결 정보 — 실제 값은 .streamlit/secrets.toml 에 넣고 git 에 올리지 말 것
[supabase]
url = "https://<project-ref>.supabase.co"
anon_key = "eyJ...앱_클라이언트용_anon_key..."
# service_role_key 는 앱(클라이언트)에 두지 않는다. 서버측 배치/관리 스크립트 전용.

[app]
default_due_days = 14          # 기본 반납기한(일)
overdue_alert_days = [3, 1, 0] # 반납 D-3 / D-1 / 당일 알림(P3)
storage_bucket_photos = "material-photos"
storage_bucket_proofs = "loan-proofs"
